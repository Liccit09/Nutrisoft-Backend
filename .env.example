# ======================================
# Configuración de Nutrisoft Backend
# ======================================
# Copia este archivo a .env y personaliza los valores
# Este archivo es ejemplo - NO incluir datos sensibles en .env real

# ======================================
# BASE DE DATOS (PostgreSQL)
# ======================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutrisoft_db
DB_USER=nutrisoft_user
DB_PASSWORD=nutrisoft_password

# ======================================
# CORREO ELECTRÓNICO (DESARROLLO - Mailpit)
# ======================================
# Para desarrollo, usa Mailpit (Docker):
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@nutrisoft.com
MAIL_FROM_NAME=Nutrisoft
MAIL_SMTP_AUTH=false
MAIL_STARTTLS_ENABLE=false
MAIL_STARTTLS_REQUIRED=false

# ======================================
# CORREO ELECTRÓNICO (PRODUCCIÓN - Gmail)
# ======================================
# Descomenta y configura para usar Gmail en producción
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu-email@gmail.com
# MAIL_PASSWORD=tu-app-password
# MAIL_FROM=tu-email@gmail.com
# MAIL_FROM_NAME=Nutrisoft
# MAIL_SMTP_AUTH=true
# MAIL_STARTTLS_ENABLE=true
# MAIL_STARTTLS_REQUIRED=true

# ======================================
# CORREO ELECTRÓNICO (PRODUCCIÓN - SendGrid)
# ======================================
# Descomenta y configura para usar SendGrid en producción
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.XXXXXXXXXXXX
# MAIL_FROM=noreply@tudominio.com
# MAIL_FROM_NAME=Nutrisoft
# MAIL_SMTP_AUTH=true
# MAIL_STARTTLS_ENABLE=true
# MAIL_STARTTLS_REQUIRED=true

# ======================================
# JWT (Autenticación)
# ======================================
JWT_SECRET=nutrisoft-secret-key-for-jwt-token-generation-and-validation-purpose-only
JWT_EXPIRATION_MS=86400000  # 24 horas en milisegundos

# ======================================
# APLICACIÓN
# ======================================
APP_NAME=Nutrisoft Backend
APP_PORT=8080
APP_CONTEXT_PATH=/api

# ======================================
# FRONTEND
# ======================================
FRONTEND_BASE_URL=http://localhost:3000

# ======================================
# LOGGING
# ======================================
LOG_LEVEL=DEBUG
LOG_LEVEL_NUTRISOFT=DEBUG
LOG_LEVEL_SPRING=DEBUG
LOG_LEVEL_HIBERNATE=DEBUG

# ======================================
# AMBIENTE
# ======================================
# Valores posibles: dev, test, prod
SPRING_PROFILES_ACTIVE=dev


